{
  "name": "@heemankv/sigints-sdk",
  "version": "1.0.2",
  "description": "sigints.club agent SDK (Solana + backend storage) for listening to signals.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./backend": {
      "types": "./dist/backend.d.ts",
      "default": "./dist/backend.js"
    },
    "./solana": {
      "types": "./dist/solana/index.d.ts",
      "default": "./dist/solana/index.js"
    },
    "./transactions": {
      "types": "./dist/transactions.d.ts",
      "default": "./dist/transactions.js"
    },
    "./publish": {
      "types": "./dist/publish.d.ts",
      "default": "./dist/publish.js"
    },
    "./tradeIntent": {
      "types": "./dist/tradeIntent.d.ts",
      "default": "./dist/tradeIntent.js"
    },
    "./crypto": {
      "types": "./dist/crypto.d.ts",
      "default": "./dist/crypto.js"
    },
    "./crypto-web": {
      "types": "./dist/crypto-web.d.ts",
      "default": "./dist/crypto-web.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-jetstream-proto.mjs",
    "dev": "tsx src/index.ts",
    "prepare": "npm run build",
    "test": "vitest run"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.10.7",
    "@grpc/proto-loader": "^0.7.12",
    "@solana/web3.js": "^1.98.0",
    "@solana/spl-token": "^0.4.12",
    "buffer": "^6.0.3",
    "protobufjs": "^7.3.2",
    "tweetnacl": "^1.0.3"
  },
  "devDependencies": {
    "@types/node": "^20.14.12",
    "tsx": "^4.16.0",
    "typescript": "^5.5.4",
    "vitest": "^1.6.0"
  }
}
