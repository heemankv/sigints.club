    "@solana/spl-token": "^0.4.12",
    "buffer": "^6.0.3",
    "protobufjs": "^7.3.2",
    "tweetnacl": "^1.0.3"
  },
  "devDependencies": {
    "@types/node": "^20.14.12",
    "tsx": "^4.16.0",
    "typescript": "^5.5.4",
    "vitest": "^1.6.0"
  }
